<mujoco model="op3 scene enhanced">
  <!--
    Enhanced OP3 scene for OpenServoSim tutorials.
    Key changes from original scene.xml:
    - Increased actuator force limits (5N -> 12N) to prevent falling
    - Higher Kp gain (21.1 -> 40) for stiffer position control
    - These values better approximate real Dynamixel XM430 servos
      which can output ~1.4 Nm stall torque
  -->
  <include file="op3.xml"/>

  <statistic center="0 0 0.2" extent="0.6"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="160" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
  </worldbody>

  <!-- Override actuator defaults: stronger servos -->
  <default>
    <position kp="40" ctrlrange="-3.141592 3.141592" forcerange="-12 12"/>
  </default>
</mujoco>
